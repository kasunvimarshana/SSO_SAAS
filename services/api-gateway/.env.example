# API Gateway – Environment Variables
# Copy this file to .env and fill in the values for your environment.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Upstream Service URLs ─────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
PRODUCT_SERVICE_URL=http://product-service:3003
INVENTORY_SERVICE_URL=http://inventory-service:3004
ORDER_SERVICE_URL=http://order-service:3005

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all (not recommended
# in production).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# These are documented for reference; values are hard-coded in the middleware.
# RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
# RATE_LIMIT_MAX=100
